doskey ga=git add $*
doskey gap=git add -p $*
doskey gb=git branch $*
doskey gbd=git branch -D $*
doskey gc=git commit $*
doskey gca=git commit --amend $*
doskey gcan=git commit --amend --no-edit $*
doskey gch=git cherry-pick $*
doskey gcm=git commit -m $*
doskey gco=git checkout $*
doskey gd=git diff $*
doskey gdc=git diff --cached $*
doskey gfo=git fetch origin $*
doskey gfocm=git fetch origin^&^&git checkout origin/main $*
doskey gform=git fetch origin^&^&git rebase origin/main
doskey gl=git log $*
doskey glg=git log --graph $*
doskey glgp=git diff --graph -p $*
doskey glp=git log -p $*
doskey gp=git push $*
doskey gpl=git pull $*
doskey gr=git rebase $*
doskey grs=git reset $*
doskey gs=git status $*
doskey gsh=git show $*
doskey gsst=git status --short $*
doskey gst=git stash $*
doskey galias=git config --global --list ^| sed -ne 's/^^alias.//p' ^| sed -e 's/=/ = /'
