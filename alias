alias nvim="~//nvim/nvim-macos-arm64/bin/nvim"
alias ga="git add"
alias ga.="git add ."
alias gap="git add -p"
alias gap.="git add -p ."
alias gb="git branch"
alias gbd="git branch -D"
alias gc="git commit"
alias gca="git commit --amend"
alias gcan="git commit --amend --no-edit"
alias gch="git cherry-pick"
alias gcm="git commit -m"
alias gco="git checkout"
alias gd="git diff"
alias gdc="git diff --cached"
alias gf="git fetch"
alias gfo="git fetch origin"
alias gfocm="git fetch origin&&git checkout origin/main"
alias gform="git fetch origin&&git rebase origin/main"
alias gl="git log"
alias glg="git log --graph"
alias glgp="git diff --graph -p"
alias glp="git log -p"
alias gp="git push"
alias gpl="git pull"
alias gr="git rebase"
alias gre="git reset"
alias grpo="git fetch origin&&git remote prune origin"
alias grp="git remote prune"
alias gs="git status"
alias gsh="git show"
alias gsst="git status --short"
alias gst="git stash"
alias galias="git config --global --list | sed -ne 's/^alias.//p' | sed -e 's/=/ = /'"

